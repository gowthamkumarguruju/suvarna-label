generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id                  String                @id @default(cuid())
  name                String
  phone               String                @unique
  whatsapp            String?
  email               String?
  preferredLanguage   String?
  marketingConsent    String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  addresses           CustomerAddress[]
  measurementProfiles MeasurementProfile[]
  orders              Order[]
}

model CustomerAddress {
  id         String  @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  label      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("India")
}

model MeasurementProfile {
  id               String             @id @default(cuid())
  customerId       String
  customer         Customer           @relation(fields: [customerId], references: [id])
  name             String
  articleType      String
  measurementType  String
  unit             String
  version          Int                @default(1)
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  values           MeasurementValue[]
}

model MeasurementValue {
  id         String               @id @default(cuid())
  profileId  String
  profile    MeasurementProfile   @relation(fields: [profileId], references: [id])
  field      String
  value      String
}

model Order {
  id                 String               @id @default(cuid())
  orderNumber        String               @unique
  customerId         String
  customer           Customer             @relation(fields: [customerId], references: [id])
  source             String
  status             String
  productionStatus   String
  paymentStatus      String
  fulfilmentStatus   String
  mediaStatus        String
  requiredBy         DateTime?
  subtotal           Decimal              @db.Decimal(12, 2)
  discount           Decimal              @db.Decimal(12, 2) @default(0)
  shippingCharge     Decimal              @db.Decimal(12, 2) @default(0)
  total              Decimal              @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  items              OrderItem[]
  payments           Payment[]
  productionJobs     ProductionJob[]
  shipments          Shipment[]
  orderStatusHistory OrderStatusHistory[]
  media              OrderMedia[]
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  order                 Order    @relation(fields: [orderId], references: [id])
  productId             String?
  articleType           String
  orderType             String
  description           String
  color                 String?
  fabric                String?
  quantity              Int      @default(1)
  unitPrice             Decimal  @db.Decimal(12, 2)
  stitchingCharge       Decimal  @db.Decimal(12, 2) @default(0)
  customizationCharge   Decimal  @db.Decimal(12, 2) @default(0)
  measurementSnapshot   Json?
  customizationSnapshot Json?
}

model ProductionJob {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  orderItemId   String
  status        String
  assignedTo    String?
  startedAt     DateTime?
  completedAt   DateTime?
  qcNotes       String?
}

model Payment {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id])
  provider            String?
  providerPaymentId   String?
  providerPaymentLink String?
  method              String
  amount              Decimal   @db.Decimal(12, 2)
  status              String
  transactionReference String?
  paidAt              DateTime?
  reconciledAt        DateTime?
}

model Shipment {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id])
  type                String
  provider            String?
  trackingNumber      String?
  deliveryPerson      String?
  status              String
  estimatedDelivery   DateTime?
  deliveredAt         DateTime?
  codAmount           Decimal?  @db.Decimal(12, 2)
}

model OrderMedia {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  url       String
  caption   String?
  approved  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  group      String
  fromValue  String?
  toValue    String?
  notes      String?
  createdAt  DateTime @default(now())
}

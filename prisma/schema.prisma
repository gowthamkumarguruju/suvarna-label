generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSource {
  PHONE
  WHATSAPP
  WEBSITE
  INSTAGRAM
  WALK_IN
  MARKETPLACE
  ADMIN
}

enum OrderStatus {
  DRAFT
  AWAITING_CONFIRMATION
  CONFIRMED
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProductionStatus {
  NOT_STARTED
  CUTTING
  STITCHING
  FINISHING
  QUALITY_CHECK
  READY_FOR_PHOTOGRAPHY
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  ADVANCE_PAID
  PARTIALLY_PAID
  PAID
  COD_PENDING
  REFUNDED
}

enum FulfilmentStatus {
  NOT_READY
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
}

enum MediaStatus {
  NOT_REQUIRED
  PHOTOGRAPHY_PENDING
  IMAGES_UPLOADED
  AI_PROCESSING
  INTERNAL_REVIEW
  CUSTOMER_APPROVAL
  APPROVED
  PUBLISHED
}

enum InventoryMovementType {
  PURCHASE
  RECEIVED
  RESERVE
  RELEASE
  CONSUME
  RETURN
  DAMAGE
  WASTAGE
  CORRECTION
}

enum MediaKind {
  ORIGINAL
  AI_GENERATED
  FINAL
  VIDEO
  THUMBNAIL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum PublishChannel {
  WEBSITE
  INSTAGRAM
  YOUTUBE
  WHATSAPP
}

model AdminUser {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  role      String
  createdAt DateTime   @default(now())
  auditLogs AuditLog[]
}

model Customer {
  id                  String               @id @default(cuid())
  name                String
  phone               String               @unique
  whatsapp            String?
  email               String?
  preferredLanguage   String?
  marketingConsent    String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  addresses            CustomerAddress[]
  measurementProfiles MeasurementProfile[]
  orders               Order[]
  approvals            CustomerApproval[]
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("India")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model MeasurementProfile {
  id              String             @id @default(cuid())
  customerId      String
  name            String
  articleType     String
  measurementType String
  unit            String
  version         Int                @default(1)
  approvedAt      DateTime?
  createdAt       DateTime           @default(now())
  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  values          MeasurementValue[]
}

model MeasurementValue {
  id        String             @id @default(cuid())
  profileId String
  field     String
  value     String
  profile   MeasurementProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String           @id @default(cuid())
  categoryId  String
  name        String
  description String?
  madeToOrder Boolean          @default(false)
  active      Boolean          @default(true)
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]
  mediaAssets MediaAsset[]
  socialPosts SocialPost[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  sku       String  @unique
  color     String?
  size      String?
  price     Decimal @db.Decimal(12, 2)
  onHand    Decimal @default(0) @db.Decimal(12, 3)
  reserved  Decimal @default(0) @db.Decimal(12, 3)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RawMaterial {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  category        String
  unit            String
  onHand          Decimal              @default(0) @db.Decimal(12, 3)
  reserved        Decimal              @default(0) @db.Decimal(12, 3)
  reorderLevel    Decimal              @default(0) @db.Decimal(12, 3)
  purchaseCost    Decimal?             @db.Decimal(12, 2)
  supplierName    String?
  storageLocation String?
  movements       InventoryMovement[]
  productionUses  ProductionMaterial[]
}

model InventoryMovement {
  id            String                @id @default(cuid())
  rawMaterialId String
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(12, 3)
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime              @default(now())
  rawMaterial   RawMaterial           @relation(fields: [rawMaterialId], references: [id])
}

model Order {
  id               String               @id @default(cuid())
  orderNumber      String               @unique
  customerId       String
  source           OrderSource
  status           OrderStatus          @default(DRAFT)
  productionStatus ProductionStatus     @default(NOT_STARTED)
  paymentStatus    PaymentStatus        @default(UNPAID)
  fulfilmentStatus FulfilmentStatus     @default(NOT_READY)
  mediaStatus      MediaStatus          @default(NOT_REQUIRED)
  requiredBy       DateTime?
  subtotal         Decimal              @db.Decimal(12, 2)
  discount         Decimal              @default(0) @db.Decimal(12, 2)
  shippingCharge   Decimal              @default(0) @db.Decimal(12, 2)
  total            Decimal              @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  customer         Customer             @relation(fields: [customerId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  productionJobs   ProductionJob[]
  shipments        Shipment[]
  statusHistory    OrderStatusHistory[]
  mediaAssets      MediaAsset[]
  approvals        CustomerApproval[]
}

model OrderItem {
  id                    String         @id @default(cuid())
  orderId               String
  productId             String?
  articleType           String
  orderType             String
  description           String
  color                 String?
  fabric                String?
  quantity              Int            @default(1)
  unitPrice             Decimal        @db.Decimal(12, 2)
  stitchingCharge       Decimal        @default(0) @db.Decimal(12, 2)
  customizationCharge   Decimal        @default(0) @db.Decimal(12, 2)
  measurementSnapshot   Json?
  customizationSnapshot Json?
  order                 Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product?       @relation(fields: [productId], references: [id])
  productionJob         ProductionJob?
}

model ProductionJob {
  id           String             @id @default(cuid())
  orderId      String
  orderItemId  String             @unique
  status       ProductionStatus   @default(NOT_STARTED)
  assignedTo   String?
  startedAt    DateTime?
  completedAt  DateTime?
  qcNotes      String?
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem    OrderItem          @relation(fields: [orderItemId], references: [id])
  materials    ProductionMaterial[]
}

model ProductionMaterial {
  id              String        @id @default(cuid())
  productionJobId String
  rawMaterialId   String
  estimatedQty    Decimal       @db.Decimal(12, 3)
  actualQty       Decimal?      @db.Decimal(12, 3)
  productionJob   ProductionJob @relation(fields: [productionJobId], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial   @relation(fields: [rawMaterialId], references: [id])
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String
  provider             String?
  providerPaymentId    String?
  providerPaymentLink  String?
  method               String
  amount               Decimal       @db.Decimal(12, 2)
  status               PaymentStatus
  transactionReference String?
  paidAt               DateTime?
  reconciledAt         DateTime?
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id                String            @id @default(cuid())
  orderId           String
  type              String
  provider          String?
  trackingNumber    String?
  deliveryPerson    String?
  status            FulfilmentStatus  @default(NOT_READY)
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  codAmount         Decimal?          @db.Decimal(12, 2)
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id         String      @id @default(cuid())
  orderId    String?
  productId  String?
  kind       MediaKind
  url        String
  imageType  String?
  version    Int         @default(1)
  status     MediaStatus @default(IMAGES_UPLOADED)
  prompt     String?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  order      Order?      @relation(fields: [orderId], references: [id])
  product    Product?    @relation(fields: [productId], references: [id])
}

model CustomerApproval {
  id          String         @id @default(cuid())
  customerId  String
  orderId     String
  status      ApprovalStatus @default(PENDING)
  comments    String?
  sentAt      DateTime?
  viewedAt    DateTime?
  respondedAt DateTime?
  customer    Customer       @relation(fields: [customerId], references: [id])
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SocialPost {
  id          String         @id @default(cuid())
  productId   String
  channel     PublishChannel
  title       String?
  caption     String?
  mediaUrls   Json?
  status      String
  scheduledAt DateTime?
  publishedAt DateTime?
  externalUrl String?
  views       Int            @default(0)
  engagement  Int            @default(0)
  leads       Int            @default(0)
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  group     String
  fromValue String?
  toValue   String
  notes     String?
  changedBy String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime   @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
}
